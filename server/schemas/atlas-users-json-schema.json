{
  "$jsonSchema": {
    "bsonType": "object",
    "additionalProperties": true,
    "required": ["_id", "createdAt", "email", "passwordHash"],
    "properties": {
      "_id": { "bsonType": "objectId" },
      "createdAt": { "bsonType": "date" },
      "email": { "bsonType": "string" },
      "passwordHash": { "bsonType": "string" },
      "name": { "bsonType": "string", "maxLength": 200 }
    }
  }
}
